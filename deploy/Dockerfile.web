FROM node:20-alpine AS build
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app
COPY web/package.json web/pnpm-lock.yaml ./
COPY web/patches/ patches/
RUN pnpm install --frozen-lockfile
COPY web/ .
ARG VITE_HOST_MODE="oss"
ARG VITE_API_BASE_URL=""
ARG VITE_SUPABASE_URL=""
ARG VITE_SUPABASE_PUBLISHABLE_KEY=""
ARG VITE_ACCOUNT_URL=""
ARG VITE_CDN_BASE=""
ENV VITE_HOST_MODE=${VITE_HOST_MODE}
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
ENV VITE_SUPABASE_PUBLISHABLE_KEY=${VITE_SUPABASE_PUBLISHABLE_KEY}
ENV VITE_ACCOUNT_URL=${VITE_ACCOUNT_URL}
ENV VITE_CDN_BASE=${VITE_CDN_BASE}
RUN pnpm run build

FROM alpine:3.20
COPY --from=build /app/dist /dist
RUN chmod -R 755 /dist
CMD ["echo", "Frontend build complete. Use docker cp to extract /dist."]
